# --- Externes (tous optionnels pour l'instant : l'app fonctionne en mode stub) ---

# Anthropic (Claude) — utilisé côté serveur uniquement pour générer la réponse IA.
# Tant que la clé n'est pas branchée, src/lib/ai.ts retourne un texte local.
ANTHROPIC_API_KEY=
# Optionnel : modèle (défaut: claude-opus-4-8 ; économique: claude-haiku-4-5).
ANTHROPIC_MODEL=

# CRM (GoHighLevel ou autre) — webhook entrant qui reçoit le lead.
# Si vide, src/lib/crm.ts logue le payload côté serveur au lieu de l'envoyer.
CRM_WEBHOOK_URL=

# Supabase (à brancher plus tard pour persister les leads / dashboard admin).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
